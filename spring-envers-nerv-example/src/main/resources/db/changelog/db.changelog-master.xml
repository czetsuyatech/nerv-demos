<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!-- Define schema variable -->
  <property name="schemaName" value="nervaudit"/>

  <!-- Create schema -->
  <changeSet id="0" author="ed">
    <sql>CREATE SCHEMA IF NOT EXISTS ${schemaName};</sql>
  </changeSet>

  <!-- Include other changelogs -->
  <include file="001-initial-schema.xml" relativeToChangelogFile="true"/>
  <include file="002-user-audit-tables.xml" relativeToChangelogFile="true"/>

</databaseChangeLog>
