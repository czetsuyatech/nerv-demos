<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="001-seq-revinfo" author="edward">
    <createSequence sequenceName="revinfo_seq" schemaName="${schemaName}" startValue="1" incrementBy="50"/>
  </changeSet>

  <changeSet id="002-seq-user" author="edward">
    <createSequence sequenceName="user_seq" schemaName="${schemaName}" startValue="1" incrementBy="50"/>
  </changeSet>

  <changeSet id="003-revinfo" author="edward">
    <createTable tableName="revinfo" schemaName="${schemaName}">
      <column name="rev" type="BIGINT">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="revtstmp" type="BIGINT"/>
    </createTable>
  </changeSet>

  <changeSet id="004-user-account" author="edward">
    <createTable tableName="user_account" schemaName="${schemaName}">
      <column name="id" type="BIGINT">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="birth_date" type="TIMESTAMP"/>
      <column name="first_name" type="VARCHAR(255)"/>
      <column name="last_name" type="VARCHAR(255)"/>
      <column name="username" type="VARCHAR(255)"/>
    </createTable>
  </changeSet>

</databaseChangeLog>
